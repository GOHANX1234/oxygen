<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Oxygen S itself never needs to read/write another app's real package info;
         it only ever inspects guest APKs the user explicitly hands it. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"
        xmlns:tools="http://schemas.android.com/tools" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name=".OxygenApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.OxygenS">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.OxygenS">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Stub component pool (plan §4.2 / §5).

          Android will only launch Activity/Service/Provider/Receiver classes declared
          in *this* manifest. Guest components are mapped onto free stub slots at
          runtime by VAMS (StubComponentAllocator), which loads the guest's real class
          via the clone's DexClassLoader and delegates to it by reflection once the
          stub's lifecycle callbacks fire.

          One process group per clone (":clone_0".. ":clone_N") isolates a crashing
          guest app from Oxygen S and from other clones (plan §2, "process-per-clone").
          Pool size per clone and total clone count are both finite and defined in
          StubComponentPool.kt — keep that file and this block in sync by hand; there
          is no codegen step for this yet (candidate for a Gradle task later).
        -->
        <activity
            android:name=".stub.StubActivity0"
            android:exported="false"
            android:process=":clone_0"
            android:launchMode="standard"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize" />
        <activity
            android:name=".stub.StubActivity1"
            android:exported="false"
            android:process=":clone_0"
            android:launchMode="standard"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize" />
        <activity
            android:name=".stub.StubActivity2"
            android:exported="false"
            android:process=":clone_1"
            android:launchMode="standard"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize" />
        <activity
            android:name=".stub.StubActivity3"
            android:exported="false"
            android:process=":clone_1"
            android:launchMode="standard"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize" />

        <service
            android:name=".stub.StubService0"
            android:exported="false"
            android:process=":clone_0" />
        <service
            android:name=".stub.StubService1"
            android:exported="false"
            android:process=":clone_1" />

        <provider
            android:name=".stub.StubProvider0"
            android:authorities="com.oxygens.app.stub.provider0"
            android:exported="false"
            android:process=":clone_0" />
        <provider
            android:name=".stub.StubProvider1"
            android:authorities="com.oxygens.app.stub.provider1"
            android:exported="false"
            android:process=":clone_1" />

        <receiver
            android:name=".stub.StubReceiver0"
            android:exported="false"
            android:process=":clone_0" />
        <receiver
            android:name=".stub.StubReceiver1"
            android:exported="false"
            android:process=":clone_1" />

    </application>

</manifest>
